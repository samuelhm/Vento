generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id            String    @id @default(uuid()) // Unique character ID
  productId     String    // ID Product - Service Catalog
  productOwner  String    // ID salesperson (security)
  buyerId       String    // ID buyerId

  createdAt     DateTime  @default(now()) // Time created
  updatedAt     DateTime  @updatedAt // auto update

  messages      Message[] // relation 1-n

  @@unique([productId, buyerId]) // 1 chat - for buyer
}

model Message {
  id              String        @id @default(uuid())

  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id])

  senderId        String      // Who send the messages
  content         String      // Msg text

  type            String      @default("TEXT") // type: text, img, sales, system

  // if It is an offer, we save the amount
  offerAmount     Decimal?     @db.Decimal(10, 2)

  read            Boolean     @default(false) // double check
  createdAt       DateTime    @default(now())
}
